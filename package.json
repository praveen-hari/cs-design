{
  "name": "@syncfusion/cs-design",
  "version": "0.1.0",
  "description": "CLI + SDK for design system context for AI coding agents",
  "license": "MIT",
  "author": "Syncfusion",
  "type": "module",
  "bin": {
    "cs-design": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@google/design.md": "^0.3.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "design-system",
    "ai",
    "cli",
    "sdk",
    "design-tokens",
    "ui-design",
    "agent",
    "syncfusion",
    "design.md",
    "linter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/cs-design"
  }
}
