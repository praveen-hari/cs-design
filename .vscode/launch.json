{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--import", "tsx"],
      "args": ["${workspaceFolder}/src/cli.ts", "init", "Test App"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug CLI (validate)",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["--import", "tsx"],
      "args": ["${workspaceFolder}/src/cli.ts", "validate"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
